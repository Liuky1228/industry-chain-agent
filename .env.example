# DeepSeek API 配置（硅基流动 SiliconFlow）
# 请前往 https://cloud.siliconflow.cn 注册并获取 API Key
DEEPSEEK_API_KEY=你的API_KEY粘贴到这里
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3

# 数据库（一般不需要修改）
DATABASE_URL=sqlite:///./data/industry_chain.db

# 爬虫配置
CRAWL_DELAY_SECONDS=3
MAX_REPORTS_PER_TASK=60
REPORT_DATE_RANGE_DAYS=365
